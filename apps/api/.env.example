# Copy to .env for local dev.
# Dev uses SQLite (zero setup). For Postgres, change the datasource provider in
# prisma/schema.prisma to "postgresql" and use a postgres:// URL here.
DATABASE_URL="file:./dev.db"

PORT=3000
CORS_ORIGIN="http://localhost:5173,http://localhost:8100"

# --- Auth ---
JWT_SECRET="dev-only-change-me-in-production-please-32+chars"
JWT_EXPIRES_IN="7d"

# --- Media (local dev storage) ---
UPLOAD_DIR="uploads"
PUBLIC_BASE_URL="http://localhost:3000"
