{
  "name": "thunder-eats",
  "version": "0.1.0",
  "private": true,
  "description": "雷評 / 踩雷餐廳 — bad-restaurant discovery MVP (web + iPhone)",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:api": "pnpm --filter @thunder/api dev",
    "dev:mobile": "pnpm --filter @thunder/mobile dev",
    "db:setup": "pnpm --filter @thunder/api db:setup",
    "db:seed": "pnpm --filter @thunder/api db:seed",
    "db:reset": "pnpm --filter @thunder/api db:reset"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "prisma",
      "@prisma/client",
      "@prisma/engines"
    ]
  }
}
